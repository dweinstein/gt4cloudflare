					"uidString" : "7uOD8H7OSbymrwfXc83dpg=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "### 6.2 Webhook Receiver with KV Storage\n\nStores incoming webhook events in KV with 30-day TTL. GET `/events` lists stored events. Requires `kv_namespace` binding named `WEBHOOK_EVENTS`."
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:11:01.834264-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:11:01.834264-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "V0lsCpcOSMyn8aikIQB12A=="
				},
				"code" : "\"Webhook receiver with KV storage (JavaScript ES Module)\"\n'export default {\n  async fetch(request, env, ctx) {\n    const url = new URL(request.url);\n\n    // POST / -- receive and store webhook event\n    if (request.method === ''POST'') {\n      const body = await request.text();\n      const eventId = crypto.randomUUID();\n      const timestamp = new Date().toISOString();\n\n      const event = JSON.stringify({\n        id: eventId,\n        timestamp: timestamp,\n        headers: Object.fromEntries(request.headers),\n        body: body,\n        source: request.headers.get(''x-webhook-source'') || ''unknown'',\n      });\n\n      // Store in KV with 30-day TTL\n      await env.WEBHOOK_EVENTS.put(\n        `event:${timestamp}:${eventId}`,\n        event,\n        { expirationTtl: 60 * 60 * 24 * 30 }\n      );\n\n      return new Response(JSON.stringify({ id: eventId, status: ''stored'' }), {\n        status: 201,\n        headers: { ''Content-Type'': ''application/json'' },\n      });\n    }\n\n    // GET /events -- list stored events\n    if (request.method === ''GET'' && url.pathname === ''/events'') {\n      const list = await env.WEBHOOK_EVENTS.list({ prefix: ''event:'', limit: 50 });\n      const events = [];\n      for (const key of list.keys) {\n        const value = await env.WEBHOOK_EVENTS.get(key.name);\n        if (value) events.push(JSON.parse(value));\n      }\n      return new Response(JSON.stringify(events), {\n        headers: { ''Content-Type'': ''application/json'' },\n      });\n    }\n\n    return new Response(''Not found'', { status: 404 });\n  },\n};'"
			},
