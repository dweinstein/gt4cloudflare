				"uid" : {
					"__type" : "uid",
					"uidString" : "yaEaRXfhSACgWqVIzDzURw=="
				},
				"code" : "\"Example metadata JSON structure\"\n'{\n  \"main_module\": \"main.js\",\n  \"compatibility_date\": \"2024-09-14\",\n  \"compatibility_flags\": [\"nodejs_compat\"],\n  \"bindings\": [\n    { \"type\": \"kv_namespace\", \"name\": \"MY_KV\", \"namespace_id\": \"abc123\" },\n    { \"type\": \"plain_text\", \"name\": \"WEBHOOK_TARGET\", \"text\": \"https://example.com/hook\" },\n    { \"type\": \"secret_text\", \"name\": \"AUTH_TOKEN\", \"text\": \"secret-value\" },\n    { \"type\": \"d1\", \"name\": \"DB\", \"id\": \"database-uuid\" }\n  ]\n}'"
			},
