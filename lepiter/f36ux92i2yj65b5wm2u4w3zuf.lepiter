				"uid" : {
					"__type" : "uid",
					"uidString" : "3Yli1lX/RNWjkIqKD6o9Mw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "### 6.1 Basic Webhook Forwarder\n\nReceives POST, forwards body and content-type to a configured target URL. Target set via `plain_text` binding `WEBHOOK_TARGET`."
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:10:48.50009-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:10:48.50009-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "3dFbIDGtRl6QGry+YOLTpg=="
				},
				"code" : "\"Webhook forwarder Worker script (JavaScript ES Module)\"\n'export default {\n  async fetch(request, env, ctx) {\n    if (request.method !== ''POST'') {\n      return new Response(''Method not allowed'', { status: 405 });\n    }\n\n    const body = await request.text();\n    const contentType = request.headers.get(''content-type'') || ''application/json'';\n    const targetUrl = env.WEBHOOK_TARGET;\n\n    const forwardResponse = await fetch(targetUrl, {\n      method: ''POST'',\n      headers: {\n        ''Content-Type'': contentType,\n        ''X-Forwarded-From'': new URL(request.url).hostname,\n      },\n      body: body,\n    });\n\n    return new Response(JSON.stringify({\n      status: ''forwarded'',\n      target_status: forwardResponse.status,\n    }), {\n      headers: { ''Content-Type'': ''application/json'' },\n    });\n  },\n};'"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:10:53.454527-04:00"
					}
				},
				"editEmail" : {
