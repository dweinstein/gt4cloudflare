				"code" : "| view |\rview := GtPhlowColumnedListView new.\rview items: [ {\r  { 'Upload/Update Script'. 'PUT'. '/accounts/{account_id}/workers/scripts/{script_name}' }.\r  { 'List Scripts'. 'GET'. '/accounts/{account_id}/workers/scripts' }.\r  { 'Download Script'. 'GET'. '/accounts/{account_id}/workers/scripts/{script_name}' }.\r  { 'Delete Script'. 'DELETE'. '/accounts/{account_id}/workers/scripts/{script_name}' }.\r  { 'Get Script Settings'. 'GET'. '/accounts/{account_id}/workers/scripts/{script_name}/script-settings' }.\r  { 'Update Script Settings'. 'PATCH'. '/accounts/{account_id}/workers/scripts/{script_name}/script-settings' }\r} ].\rview column: 'Operation' text: [ :row | row at: 1 ] weight: 0.3.\rview column: 'Method' text: [ :row | row at: 2 ] weight: 0.1.\rview column: 'Endpoint' text: [ :row | row at: 3 ] weight: 0.6.\rview asElement",
