				"code" : "| view |\rview := GtPhlowColumnedListView new.\rview items: [ {\r  { 'kv_namespace'. 'name, namespace_id'. 'KV storage' }.\r  { 'd1'. 'name, id'. 'D1 SQLite database' }.\r  { 'r2_bucket'. 'name, bucket_name'. 'Object storage' }.\r  { 'plain_text'. 'name, text'. 'Environment variable' }.\r  { 'secret_text'. 'name, text'. 'Encrypted secret' }.\r  { 'service'. 'name, service, environment'. 'Service binding' }.\r  { 'durable_object_namespace'. 'name, class_name'. 'Durable Objects' }.\r  { 'queue'. 'name, queue_name'. 'Queue' }.\r  { 'ai'. 'name'. 'Workers AI' }.\r  { 'analytics_engine'. 'name, dataset'. 'Analytics' }.\r  { 'browser_rendering'. 'name'. 'Browser rendering' }.\r  { 'hyperdrive'. 'name, id'. 'DB connection pooling' }.\r  { 'vectorize'. 'name, index_name'. 'Vector DB' }.\r  { 'mtls_certificate'. 'name, certificate_id'. 'mTLS' }.\r  { 'version_metadata'. 'name'. 'Version info' }.\r  { 'assets'. 'name'. 'Static assets' }\r} ].\rview column: 'type' text: [ :row | row at: 1 ] weight: 0.3.\rview column: 'Required Fields' text: [ :row | row at: 2 ] weight: 0.35.\rview column: 'Purpose' text: [ :row | row at: 3 ] weight: 0.35.\rview asElement",
