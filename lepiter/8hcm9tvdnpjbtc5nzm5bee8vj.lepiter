				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "# Low-Level Workers API\n\nThe {{gtClass:Gt4CloudflareWorkersClient}} also exposes the full Cloudflare Workers REST API for direct use:"
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:21:25.366753-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T22:21:25.366753-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "JIuNfFLyRnCwcjbskqBacQ=="
				},
				"code" : "client := Gt4CloudflareWorkersClient withApiKeyFromFile\n\taccountId: 'YOUR_ACCOUNT_ID'.\n\n\"List all Worker scripts\"\nclient listScripts.\n\n\"Upload a custom Worker script\"\nclient uploadScript: 'my-worker' code: 'export default { async fetch(req) { return new Response(\"hello\"); } }'.\n\n\"Manage KV namespaces\"\nclient listKvNamespaces.\nns := client createKvNamespace: 'my-store'.\nclient kvPut: 'key1' value: 'hello world' namespace: ns id.\nclient kvGet: 'key1' namespace: ns id.\n\n\"Get the workers.dev subdomain\"\nclient getSubdomain.\nclient scriptUrl: 'my-worker'."
			},
			{
				"__type" : "textSnippet",
