					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "cbl8lfDdRpuEwMpgO+KRqg=="
				},
				"code" : "\"Clear all stored events\"\nwebhook clearEvents.\n\n\"Check how many events are stored\"\nwebhook eventCount.\n\n\"Teardown: delete the Worker script and KV namespace\"\nwebhook teardown."
			},
